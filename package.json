    "express": "^4.17.2",
    "moment": "^2.30.1",
    "mongodb": "^3.7.4",
    "mongoose": "^6.13.8",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.23",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.8.1",
