<%- include('../includes/header', { title: 'Admin Dashboard', page: 'admin' }) %>

<main style="padding-top:var(--nav-h);">

  <div class="page-header" style="background:linear-gradient(135deg,#1B2A4A,#2D4A6A);">
    <div class="container">
      <h1 class="section-title" style="color:#fff;">
        🏪 Admin Dashboard
      </h1>
      <p style="color:rgba(255,255,255,0.65);">
        Welcome back, <strong style="color:#C8860A;"><%= typeof member !== 'undefined' && member ? member.memberNick : 'Admin' %></strong>
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <!-- Stats cards -->
      <div class="card-grid card-grid-3" style="margin-bottom:3rem;">
        <div class="card" style="text-align:center;padding:2rem;">
          <div style="font-size:2.5rem;margin-bottom:0.5rem;">👥</div>
          <div style="font-size:2rem;font-weight:700;color:#1B2A4A;font-family:var(--font-display);">
            <%= typeof members !== 'undefined' ? members.length : 0 %>
          </div>
          <div style="color:var(--text-muted);font-size:0.9rem;">Total Members</div>
        </div>
        <div class="card" style="text-align:center;padding:2rem;">
          <div style="font-size:2.5rem;margin-bottom:0.5rem;">🍽️</div>
          <div style="font-size:2rem;font-weight:700;color:#C8860A;font-family:var(--font-display);">200+</div>
          <div style="color:var(--text-muted);font-size:0.9rem;">Menu Items</div>
        </div>
        <div class="card" style="text-align:center;padding:2rem;">
          <div style="font-size:2.5rem;margin-bottom:0.5rem;">⭐</div>
          <div style="font-size:2rem;font-weight:700;color:#166534;font-family:var(--font-display);">4.9</div>
          <div style="color:var(--text-muted);font-size:0.9rem;">Average Rating</div>
        </div>
      </div>

      <!-- Members table -->
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">All Members</span>
          <form action="/admin/logout" method="POST" style="margin:0;">
            <button type="submit" class="btn btn-outline" style="padding:0.5rem 1rem;color:#991B1B;border-color:#991B1B;">
              🚪 Logout
            </button>
          </form>
        </div>
        <div style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>Member</th>
                <th>Username</th>
                <th>Phone</th>
                <th>Type</th>
                <th>Status</th>
                <th>Points</th>
                <th>Joined</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof members !== 'undefined' && members.length > 0) { %>
                <% members.forEach(function(m) { %>
                  <tr>
                    <td><div class="avatar"><%= m.memberNick ? m.memberNick.charAt(0).toUpperCase() : '?' %></div></td>
                    <td style="font-weight:600;"><%= m.memberNick %></td>
                    <td style="color:var(--text-muted);"><%= m.memberPhone || '—' %></td>
                    <td>
                      <% if (m.membertype === 'RESTAURANT') { %>
                        <span class="badge badge-restaurant">🏪 Restaurant</span>
                      <% } else { %>
                        <span class="badge badge-user">👤 User</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (m.memberStatus === 'ACTIVE') { %>
                        <span class="badge badge-active">✅ Active</span>
                      <% } else { %>
                        <span class="badge badge-blocked">🚫 Blocked</span>
                      <% } %>
                    </td>
                    <td style="color:var(--primary);font-weight:600;"><%= m.memberPoints || 0 %> pts</td>
                    <td style="color:var(--text-muted);font-size:0.85rem;">
                      <%= m.createdAt ? new Date(m.createdAt).toLocaleDateString('en-GB') : '—' %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" style="text-align:center;padding:3rem;color:var(--text-muted);">
                    No members found yet.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
    
  </section>
</main>

<%- include('../includes/footer') %>
