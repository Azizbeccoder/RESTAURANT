<%- include('../includes/header', { title: 'Admin Register', page: 'admin' }) %>

<main class="form-wrap">
  <div class="form-card">

    <div class="form-logo" style="color:#1B2A4A;">
      🏪 <span style="color:#C8860A;">Restaurant</span> Register
    </div>
    <p class="form-subtitle">Create a restaurant admin account</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>

    <div style="background:#DCFCE7;border:1px solid #166534;border-radius:12px;padding:12px 16px;margin-bottom:1.2rem;">
      <p style="font-size:0.82rem;color:#166534;margin:0;">
        ✅ Restaurant accounts get full admin access to manage menu and orders.
      </p>
    </div>

    <form action="/admin/signup" method="POST" id="adminSignupForm" novalidate>

      <div class="form-group">
        <label class="form-label" for="memberNick">Restaurant Username</label>
        <div class="form-input-icon">
          <span class="icon">🏪</span>
          <input class="form-input" type="text" id="memberNick" name="memberNick"
            placeholder="Choose a unique username"
            value="<%= (formData && formData.memberNick) ? formData.memberNick : '' %>"
            required minlength="3" autocomplete="username"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="memberPhone">Phone Number</label>
        <div class="form-input-icon">
          <span class="icon">📱</span>
          <input class="form-input" type="tel" id="memberPhone" name="memberPhone"
            placeholder="+998 90 000 00 00"
            value="<%= (formData && formData.memberPhone) ? formData.memberPhone : '' %>"
            required autocomplete="tel"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="memberPassword">Password</label>
        <div class="form-input-icon">
          <span class="icon">🔒</span>
          <input class="form-input" type="password" id="memberPassword" name="memberPassword"
            placeholder="At least 6 characters" required minlength="6" autocomplete="new-password"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="memberAddress">Restaurant Address</label>
        <div class="form-input-icon">
          <span class="icon">📍</span>
          <input class="form-input" type="text" id="memberAddress" name="memberAddress"
            placeholder="Restaurant address" autocomplete="street-address"/>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg" style="background:#1B2A4A;">
        Create Restaurant Account →
      </button>

    </form>

    <div class="form-footer">
      Already have an admin account? <a href="/admin/login">Admin Login</a>
    </div>

  </div>
</main>

<%- include('../includes/footer') %>
