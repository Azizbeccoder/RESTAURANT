<%- include('includes/header', { title: 'Home', page: 'home' }) %>

<!-- ══ HERO — full screen background ══ -->
<section class="hero-full">
  <!-- Dark overlay -->
  <div class="hero-overlay"></div>

  <!-- Background food image using CSS -->
  <div class="hero-bg"></div>

  <!-- Top info bar -->
  <div class="hero-topbar">
    <span>📞 +998 90 123 45 67</span>
    <span>✉️ hello@burak.uz</span>
    <span>🕐 Mon–Sun: 10:00AM – 10:00PM</span>
  </div>

  <!-- Center content -->
  <div class="hero-center">
    <div class="hero-script">Burak</div>
    <h1 class="hero-main">BEST RESTAURANT<br>IN TASHKENT</h1>
    <p class="hero-desc">Authentic flavors crafted with passion. Fresh ingredients, bold recipes, and memories that last a lifetime.</p>
    <div class="hero-btns">
      <a href="/products" class="btn-reserve">View Our Menu</a>
      <a href="/signup" class="btn-ghost-white">Join Free</a>
    </div>
  </div>

  <!-- Bottom dish cards row -->
  <div class="dish-cards-row">
    <div class="dish-card">
      <div class="dish-circle">
        <div class="dish-emoji">🍖</div>
      </div>
      <div class="dish-card-name">Slow-Roasted Lamb</div>
      <div class="dish-card-tags">Lamb, Herbs, Spices</div>
    </div>
    <div class="dish-card">
      <div class="dish-circle">
        <div class="dish-emoji">🥗</div>
      </div>
      <div class="dish-card-name">Mezze Platter</div>
      <div class="dish-card-tags">Hummus, Pita, Veggies</div>
    </div>
    <div class="dish-card">
      <div class="dish-circle">
        <div class="dish-emoji">🫕</div>
      </div>
      <div class="dish-card-name">Beef Tagine</div>
      <div class="dish-card-tags">Beef, Apricots, Almonds</div>
    </div>
    <div class="dish-card">
      <div class="dish-circle">
        <div class="dish-emoji">🍰</div>
      </div>
      <div class="dish-card-name">Baklava Supreme</div>
      <div class="dish-card-tags">Pistachio, Honey, Phyllo</div>
    </div>
  </div>
</section>

<!-- ══ ABOUT STRIP ══ -->
<section class="about-strip">
  <div class="container">
    <div class="about-grid">
      <div class="about-stat">
        <div class="about-num">200<span>+</span></div>
        <div class="about-label">Menu Items</div>
      </div>
      <div class="about-divider"></div>
      <div class="about-stat">
        <div class="about-num">12</div>
        <div class="about-label">Expert Chefs</div>
      </div>
      <div class="about-divider"></div>
      <div class="about-stat">
        <div class="about-num">15k<span>+</span></div>
        <div class="about-label">Happy Guests</div>
      </div>
      <div class="about-divider"></div>
      <div class="about-stat">
        <div class="about-num">4.9<span>★</span></div>
        <div class="about-label">Average Rating</div>
      </div>
    </div>
  </div>
</section>

<!-- ══ MENU SECTION ══ -->
<section class="menu-section">
  <div class="container">
    <div class="section-tag">Our Specialties</div>
    <h2 class="section-heading">Signature Dishes</h2>
    <p class="section-sub">Every dish crafted with passion and the finest ingredients</p>

    <div class="menu-grid">
      <div class="menu-item">
        <div class="menu-img">🍖</div>
        <div class="menu-info">
          <div class="menu-top">
            <span class="menu-name">Slow-Roasted Lamb</span>
            <span class="menu-price">$36</span>
          </div>
          <div class="menu-desc">24-hour marinated lamb with roasted vegetables and aromatic spices</div>
          <div class="menu-tags"><span>Best Seller</span><span>Signature</span></div>
        </div>
      </div>
      <div class="menu-item">
        <div class="menu-img">🥗</div>
        <div class="menu-info">
          <div class="menu-top">
            <span class="menu-name">Mezze Platter</span>
            <span class="menu-price">$18</span>
          </div>
          <div class="menu-desc">Hummus, baba ganoush, tabbouleh, fresh pita and seasonal vegetables</div>
          <div class="menu-tags"><span>Vegetarian</span><span>Sharing</span></div>
        </div>
      </div>
      <div class="menu-item">
        <div class="menu-img">🍗</div>
        <div class="menu-info">
          <div class="menu-top">
            <span class="menu-name">Grilled Shawarma</span>
            <span class="menu-price">$22</span>
          </div>
          <div class="menu-desc">Spiced chicken with garlic sauce, pickles and fresh herbs in warm bread</div>
          <div class="menu-tags"><span>Popular</span></div>
        </div>
      </div>
      <div class="menu-item">
        <div class="menu-img">🫕</div>
        <div class="menu-info">
          <div class="menu-top">
            <span class="menu-name">Beef Tagine</span>
            <span class="menu-price">$29</span>
          </div>
          <div class="menu-desc">Slow-cooked beef with apricots, almonds and warm Moroccan spices</div>
          <div class="menu-tags"><span>Chef's Choice</span></div>
        </div>
      </div>
      <div class="menu-item">
        <div class="menu-img">🍮</div>
        <div class="menu-info">
          <div class="menu-top">
            <span class="menu-name">Kunafa</span>
            <span class="menu-price">$11</span>
          </div>
          <div class="menu-desc">Crispy shredded pastry soaked in sweet syrup with creamy cheese filling</div>
          <div class="menu-tags"><span>Dessert</span></div>
        </div>
      </div>
      <div class="menu-item">
        <div class="menu-img">🍰</div>
        <div class="menu-info">
          <div class="menu-top">
            <span class="menu-name">Baklava Supreme</span>
            <span class="menu-price">$9</span>
          </div>
          <div class="menu-desc">Layered phyllo pastry with pistachios, walnuts and rose-water honey</div>
          <div class="menu-tags"><span>Dessert</span><span>Sweet</span></div>
        </div>
      </div>
    </div>

    <div style="text-align:center;margin-top:3rem;">
      <a href="/products" class="btn-reserve">See Full Menu</a>
    </div>
  </div>
</section>

<!-- ══ DARK STORY SECTION ══ -->
<section class="story-section">
  <div class="container">
    <div class="story-grid">
      <div class="story-left">
        <div class="story-food-grid">
          <div class="sfood s1">🥩</div>
          <div class="sfood s2">🌶️</div>
          <div class="sfood s3">🫒</div>
          <div class="sfood s4">🧄</div>
        </div>
      </div>
      <div class="story-right">
        <div class="section-tag light">Our Story</div>
        <h2 class="section-heading light">Passion on<br>Every Plate</h2>
        <p class="story-text">Founded in Tashkent with a dream to share authentic flavors from across the region. Our chefs bring decades of culinary expertise, using only the freshest locally-sourced ingredients.</p>
        <p class="story-text">Every dish is a journey — from the fragrant spice markets to your table. We believe great food brings people together.</p>
        <div class="story-features">
          <div class="story-feat"><span class="feat-icon">🌿</span><span>Farm-fresh ingredients daily</span></div>
          <div class="story-feat"><span class="feat-icon">👨‍🍳</span><span>Master chefs with 20+ years experience</span></div>
          <div class="story-feat"><span class="feat-icon">🚀</span><span>30-minute delivery guarantee</span></div>
        </div>
        <a href="/users" class="btn-reserve" style="margin-top:2rem;display:inline-block;">Meet Our Community</a>
      </div>
    </div>
  </div>
</section>

<!-- ══ TESTIMONIALS ══ -->
<section class="testi-section">
  <div class="container">
    <div class="section-tag">Reviews</div>
    <h2 class="section-heading">What Guests Say</h2>
    <div class="testi-grid">
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <p class="testi-text">"The lamb was cooked to absolute perfection. Best restaurant experience I've had in Tashkent."</p>
        <div class="testi-author">
          <div class="testi-avatar">AK</div>
          <div><div class="testi-name">Aziz Karimov</div><div class="testi-role">Food Blogger</div></div>
        </div>
      </div>
      <div class="testi-card featured">
        <div class="testi-stars">★★★★★</div>
        <p class="testi-text">"Food arrived hot within 25 minutes. Beautiful packaging and the taste was absolutely outstanding!"</p>
        <div class="testi-author">
          <div class="testi-avatar">SN</div>
          <div><div class="testi-name">Sabohat Nazarova</div><div class="testi-role">Regular Customer</div></div>
        </div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <p class="testi-text">"The baklava is simply heaven. I've been coming here every week for the past year."</p>
        <div class="testi-author">
          <div class="testi-avatar">JM</div>
          <div><div class="testi-name">Jasur Mirzayev</div><div class="testi-role">VIP Member</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ JOIN / CTA ══ -->
<section class="cta-section">
  <div class="cta-overlay"></div>
  <div class="cta-bg"></div>
  <div class="container cta-inner">
    <div class="section-tag light">Join Burak</div>
    <h2 class="cta-heading">Ready to Experience<br>the Best?</h2>
    <p class="cta-sub">Create a free account and start earning loyalty points with every order.</p>
    <% if (typeof member === 'undefined' || !member) { %>
      <div class="cta-btns">
        <a href="/signup" class="btn-reserve">Create Free Account</a>
        <a href="/login" class="btn-ghost-white">Log In</a>
      </div>
    <% } else { %>
      <div style="margin-top:2rem;">
        <p style="color:rgba(255,255,255,0.9);font-size:1.1rem;">Welcome back, <strong style="color:#C8860A;"><%= member.memberNick %></strong>! You have <strong style="color:#C8860A;"><%= member.memberPoints || 0 %></strong> loyalty points.</p>
        <a href="/products" class="btn-reserve" style="margin-top:1rem;display:inline-block;">Order Now</a>
      </div>
    <% } %>
  </div>
</section>

<%- include('includes/footer') %>
