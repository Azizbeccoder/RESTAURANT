<script>
document.addEventListener('DOMContentLoaded', function() {
  var navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', function() {
      navbar.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  }
  var hamburger = document.getElementById('hamburger');
  var navLinks = document.getElementById('navLinks');
  if (hamburger && navLinks) {
    hamburger.addEventListener('click', function() {
      navLinks.classList.toggle('open');
      var bars = hamburger.querySelectorAll('span');
      if (navLinks.classList.contains('open')) {
        bars[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
        bars[1].style.opacity = '0';
        bars[2].style.transform = 'rotate(-45deg) translate(5px, -5px)';
      } else {
        bars.forEach(function(b) { b.style.transform = ''; b.style.opacity = ''; });
      }
    });
  }
  var loginForm = document.getElementById('loginForm');
  var signupForm = document.getElementById('signupForm');
  function showError(input, message) {
    input.classList.add('error');
    var err = input.parentElement.querySelector('.field-error');
    if (!err) {
      err = document.createElement('p');
      err.className = 'field-error';
      err.style.cssText = 'color:#C0392B;font-size:0.78rem;margin-top:0.25rem;';
      input.parentElement.appendChild(err);
    }
    err.textContent = message;
    input.addEventListener('input', function() {
      input.classList.remove('error');
      if (err) err.textContent = '';
    });
  }
  if (loginForm) {
    loginForm.addEventListener('submit', function(e) {
      var nick = document.getElementById('memberNick');
      var pass = document.getElementById('memberPassword');
      var valid = true;
      if (!nick.value.trim()) { showError(nick, 'Username is required'); valid = false; }
      if (!pass.value.trim()) { showError(pass, 'Password is required'); valid = false; }
      if (!valid) e.preventDefault();
    });
  }
  if (signupForm) {
    signupForm.addEventListener('submit', function(e) {
      var nick = document.getElementById('memberNick');
      var pass = document.getElementById('memberPassword');
      var valid = true;
      if (!nick || nick.value.length < 3) { if(nick) showError(nick, 'At least 3 characters'); valid = false; }
      if (!pass || pass.value.length < 6) { if(pass) showError(pass, 'At least 6 characters'); valid = false; }
      if (!valid) e.preventDefault();
    });
  }
  if ('IntersectionObserver' in window) {
    var fadeEls = document.querySelectorAll('.fade-up, .fade-up-2, .fade-up-3');
    fadeEls.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(30px)';
    });
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    fadeEls.forEach(function(el) { obs.observe(el); });
  }
});
</script>
</body>
</html>
