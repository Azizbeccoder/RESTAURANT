<script>
document.addEventListener('DOMContentLoaded', function() {
  var navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', function() {
      navbar.classList.toggle('scrolled', window.scrollY > 50);
    }, { passive: true });
  }
  var hamburger = document.getElementById('hamburger');
  var navLinks  = document.getElementById('navLinks');
  if (hamburger && navLinks) {
    hamburger.addEventListener('click', function() {
      var open = navLinks.style.display === 'flex';
      navLinks.style.display = open ? 'none' : 'flex';
      navLinks.style.flexDirection = 'column';
      navLinks.style.position = 'absolute';
      navLinks.style.top = '80px';
      navLinks.style.left = '0';
      navLinks.style.right = '0';
      navLinks.style.background = 'rgba(13,10,6,0.98)';
      navLinks.style.padding = '2rem';
      navLinks.style.gap = '1.5rem';
    });
  }
  var loginForm  = document.getElementById('loginForm');
  var signupForm = document.getElementById('signupForm');
  function showError(input, msg) {
    input.style.borderColor = '#C0392B';
    var err = input.parentElement.querySelector('.ferr');
    if (!err) {
      err = document.createElement('p');
      err.className = 'ferr';
      err.style.cssText = 'color:#C0392B;font-size:0.75rem;margin-top:4px;';
      input.parentElement.appendChild(err);
    }
    err.textContent = msg;
    input.addEventListener('input', function() {
      input.style.borderColor = '';
      if (err) err.textContent = '';
    }, { once: true });
  }
  if (loginForm) {
    loginForm.addEventListener('submit', function(e) {
      var n = document.getElementById('memberNick');
      var p = document.getElementById('memberPassword');
      var ok = true;
      if (!n.value.trim()) { showError(n, 'Username required'); ok = false; }
      if (!p.value.trim()) { showError(p, 'Password required'); ok = false; }
      if (!ok) e.preventDefault();
    });
  }
  if (signupForm) {
    signupForm.addEventListener('submit', function(e) {
      var n = document.getElementById('memberNick');
      var p = document.getElementById('memberPassword');
      var ok = true;
      if (n && n.value.length < 3) { showError(n, 'At least 3 characters'); ok = false; }
      if (p && p.value.length < 6) { showError(p, 'At least 6 characters'); ok = false; }
      if (!ok) e.preventDefault();
    });
  }
});
</script>
</body>
