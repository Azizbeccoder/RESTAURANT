<%- include('includes/header', { title: error_code || '404', page: '' }) %>

<main style="padding-top:var(--nav-h);min-height:80vh;display:flex;align-items:center;justify-content:center;">
  <div style="text-align:center;padding:3rem 2rem;">
    <div style="font-size:6rem;margin-bottom:1rem;"><%= error_code === 500 ? '💥' : '🍽️' %></div>
    <h1 style="font-family:var(--font-display);font-size:5rem;font-weight:700;color:var(--primary);margin-bottom:0.5rem;">
      <%= error_code || 404 %>
    </h1>
    <h2 style="font-family:var(--font-display);font-size:1.8rem;color:var(--dark);margin-bottom:1rem;">
      <%= error_message || 'Page Not Found' %>
    </h2>
    <p style="color:var(--text-muted);font-size:1rem;max-width:400px;margin:0 auto 2rem;">
      <% if (error_code === 500) { %>
        Something went wrong on our end. Please try again later.
      <% } else { %>
        The page you are looking for does not exist or has been moved.
      <% } %>
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/" class="btn btn-primary btn-lg">🏠 Go Home</a>
      <a href="/products" class="btn btn-outline btn-lg">🍖 View Menu</a>
    </div>
  </div>
</main>

<%- include('includes/footer') %>